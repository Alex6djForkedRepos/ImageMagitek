<UserControl
    x:Class="TileShop.UI.Views.StatusView"
    x:DataType="vm:StatusViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:vm="using:TileShop.UI.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnDefinitions="auto,4,auto,*,auto,*,auto" Margin="8,0,8,0">
        <Border Grid.Column="0"
                Width="14" Height="14"
                Background="{ReflectionBinding Editors.ActiveEditor.ActivityBrush}"
                BorderBrush="Gray" BorderThickness="1"
                CornerRadius="2"
                IsVisible="{ReflectionBinding Editors.ActiveEditor.ActivityBrush, Converter={x:Static ObjectConverters.IsNotNull}}" />
        <TextBlock Grid.Column="2" Text="{ReflectionBinding Editors.ActiveEditor.ActivityMessage}" />
        <TextBlock Grid.Column="4" Text="{ReflectionBinding Editors.ActiveEditor.PendingOperationMessage}" />
        <TextBlock Grid.Column="6" Text="{Binding StatusMessage}" />
    </Grid>

</UserControl>
